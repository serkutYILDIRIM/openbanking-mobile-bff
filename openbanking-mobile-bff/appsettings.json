{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MicroserviceEndpoints": {
    "YosMicroserviceBaseUrl": "https://localhost:7101",
    "HhsMicroserviceBaseUrl": "https://localhost:7102",
    "ApiGatewayBaseUrl": "https://localhost:7100"
  },
  "HttpClientPolicy": {
    "RetryCount": 3,
    "RetryBaseDelaySeconds": 2,
    "CircuitBreakerThreshold": 5,
    "CircuitBreakerDurationSeconds": 30,
    "TimeoutSeconds": 30
  },
  "RateLimit": {
    "PermitLimit": 100,
    "WindowSeconds": 60,
    "QueueLimit": 10
  },
  "Cache": {
    "RedisConnectionString": "",
    "DefaultExpirationMinutes": 30
  },
  "JwtValidation": {
    "Issuer": "https://localhost:7100",
    "Audience": "openbanking-mobile-bff",
    "JwksUri": "https://localhost:7100/.well-known/openid-configuration",
    "ValidateLifetime": true
  },
  "OhvpsHeaders": {
    "RequestIdHeader": "X-Request-ID",
    "AspspCodeHeader": "X-ASPSP-Code",
    "TppCodeHeader": "X-TPP-Code",
    "JwsSignatureHeader": "X-JWS-Signature"
  },
  "HhsApiPaths": {
    "AccountsPath": "/hesaplar",
    "AccountByRefPath": "/hesaplar/{accountRef}",
    "BalancePath": "/hesaplar/{accountRef}/bakiye",
    "TransactionsPath": "/hesaplar/{accountRef}/islemler",
    "CardsPath": "/kartlar",
    "CardByRefPath": "/kartlar/{cardRef}",
    "CardDetailPath": "/kartlar/{cardRef}/kart-detay",
    "CardTransactionsPath": "/kartlar/{cardRef}/kart-hareketleri",
    "PaymentsPath": "/odeme-emri",
    "PaymentByIdPath": "/odeme-emri/{paymentOrderId}",
    "AccountLinkPath": ""
  },
  "Swagger": {
    "Title": "OpenBanking Mobile BFF",
    "Version": "v1",
    "Description": "OHVPS (Open Banking Turkey) Mobile Backend-For-Frontend API"
  }
}
