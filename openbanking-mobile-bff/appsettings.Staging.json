{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MicroserviceEndpoints": {
    "YosMicroserviceBaseUrl": "https://staging-yos-microservice.internal",
    "HhsMicroserviceBaseUrl": "https://staging-hhs-microservice.internal",
    "ApiGatewayBaseUrl": "https://staging-api-gateway.internal"
  },
  "HttpClientPolicy": {
    "RetryCount": 3,
    "RetryBaseDelaySeconds": 2,
    "CircuitBreakerThreshold": 5,
    "CircuitBreakerDurationSeconds": 30,
    "TimeoutSeconds": 20
  },
  "Cache": {
    "RedisConnectionString": "staging-redis.internal:6379",
    "DefaultExpirationMinutes": 30
  },
  "JwtValidation": {
    "Issuer": "https://staging-auth.internal",
    "Audience": "openbanking-mobile-bff",
    "JwksUri": "https://staging-auth.internal/.well-known/openid-configuration",
    "ValidateLifetime": true
  }
}

